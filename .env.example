# OCR Local MVP — Environment Configuration
# Copy to .env and adjust values as needed.

# App settings
APP_NAME="OCR Local MVP"
APP_VERSION="0.2.0"
LOG_LEVEL=INFO

# Processing
MAX_WORKERS=4
MAX_UPLOAD_SIZE_MB=50

# Tesseract (leave empty for auto-detection)
# Windows example:
# TESSERACT_CMD="C:\\Program Files\\Tesseract-OCR\\tesseract.exe"
TESSERACT_CMD=

# Database (default: data/ocr_local.db)
# DB_PATH=
